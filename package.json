{
  "name": "aca-twelve-steps",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next-dev.mjs",
    "build": "next build && node scripts/ensure-opennext-manifests.mjs",
    "cf:build": "opennextjs-cloudflare build && node scripts/patch-opennext-worker.mjs",
    "cf:deploy": "opennextjs-cloudflare deploy",
    "preview": "npm run cf:build && opennextjs-cloudflare preview",
    "preview:e2e": "npx wrangler d1 migrations apply DB --local && npm run preview",
    "deploy": "npm run cf:build && npm run cf:deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "next lint",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.8.3",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.2",
    "next": "15.3.9",
    "openai": "^4.104.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260312.0",
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.24",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.25.1",
    "eslint-config-next": "15.3.9",
    "playwright": "^1.53.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2",
    "wrangler": "^4.12.0"
  }
}
